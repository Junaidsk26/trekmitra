{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's full name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email", "displayName", "role"]
    },
    "Booking": {
      "title": "Trek Booking",
      "description": "Stores information about a trek booked by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who booked the trek." },
        "trekId": { "type": "string", "description": "The ID of the trek being booked." },
        "trekName": { "type": "string", "description": "The name of the trek." },
        "trekDate": { "type": "string", "format": "date", "description": "The date the trek is scheduled for." },
        "bookingDate": { "type": "string", "format": "date-time", "description": "When the booking was made." },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Cancelled"], "description": "Current status of the booking." },
        "amount": { "type": "number", "description": "Total amount paid for the booking." },
        "trekkersCount": { "type": "integer", "description": "Number of people in the booking." },
        "guidePreference": { "type": "string", "enum": ["Standard", "Special", "Male", "Female", "No Preference"], "description": "User's preference for guide configuration or gender." },
        "groupGender": { "type": "string", "enum": ["Male", "Female", "Both", ""], "description": "The gender composition of the group." },
        "preferredGuides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          },
          "description": "List of preferred guides for the trek."
        }
      },
      "required": ["userId", "trekId", "trekName", "trekDate", "status", "amount", "trekkersCount"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "A trek saved by a user for later.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user." },
        "trekId": { "type": "string", "description": "The ID of the saved trek." },
        "addedAt": { "type": "string", "format": "date-time", "description": "When the trek was added to the wishlist." }
      },
      "required": ["userId", "trekId", "addedAt"]
    },
    "Review": {
      "title": "Trek Review",
      "description": "Personal opinion and rating shared by a trekker.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who wrote the review." },
        "userName": { "type": "string", "description": "The name of the trekker." },
        "userPhoto": { "type": "string", "format": "uri", "description": "The profile picture of the trekker." },
        "trekId": { "type": "string", "description": "The ID of the trek being reviewed." },
        "trekName": { "type": "string", "description": "The name of the trek." },
        "rating": { "type": "integer", "description": "Rating from 1 to 5." },
        "comment": { "type": "string", "description": "The review text." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was posted." }
      },
      "required": ["userId", "userName", "trekId", "trekName", "rating", "comment", "createdAt"]
    },
    "Guide": {
      "title": "Trek Guide",
      "description": "Professional guide details.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Guide's full name." },
        "gender": { "type": "string", "enum": ["Male", "Female"], "description": "Guide's gender." },
        "photoURL": { "type": "string", "format": "uri", "description": "Guide's photo URL." },
        "bio": { "type": "string", "description": "Guide's biography and expertise." },
        "experience": { "type": "integer", "description": "Years of experience." },
        "rating": { "type": "number", "description": "Average rating." },
        "reviewCount": { "type": "integer", "description": "Total number of reviews." },
        "status": { "type": "string", "enum": ["Free", "Busy"], "description": "Current availability of the guide." }
      },
      "required": ["name", "gender", "photoURL", "bio", "experience", "status"]
    },
    "GuideReview": {
      "title": "Guide Review",
      "description": "User review for a specific guide.",
      "type": "object",
      "properties": {
        "guideId": { "type": "string", "description": "The ID of the guide being reviewed." },
        "userId": { "type": "string", "description": "The ID of the user who wrote the review." },
        "userName": { "type": "string", "description": "The name of the user." },
        "userPhoto": { "type": "string", "format": "uri", "description": "The profile picture of the user." },
        "rating": { "type": "integer", "description": "Rating from 1 to 5." },
        "comment": { "type": "string", "description": "The review text." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was posted." }
      },
      "required": ["guideId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "Payment": {
      "title": "Payment Information",
      "description": "Stores details about a payment transaction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who made the payment." },
        "bookingId": { "type": "string", "description": "The ID of the associated booking." },
        "amount": { "type": "number", "description": "The payment amount." },
        "currency": { "type": "string", "description": "The currency of the payment." },
        "paymentMethod": { "type": "string", "description": "The method used for payment (e.g., Credit Card, UPI)." },
        "status": { "type": "string", "enum": ["Success", "Failed", "Pending"], "description": "The status of the payment." },
        "transactionId": { "type": "string", "description": "The unique transaction ID from the payment provider." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the payment was processed." }
      },
      "required": ["userId", "bookingId", "amount", "paymentMethod", "status", "createdAt"]
    },
    "AuthLog": {
      "title": "Authentication Log",
      "description": "Logs sign-in and sign-out events.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The email of the user." },
        "event": { "type": "string", "enum": ["sign-in", "sign-out"], "description": "The type of authentication event." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the event occurred." },
        "userAgent": { "type": "string", "description": "The user agent of the browser." }
      },
      "required": ["userId", "email", "event", "timestamp"]
    },
    "PaymentMethod": {
      "title": "Saved Payment Method",
      "description": "Stores a user's saved payment method details (masked).",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user." },
        "type": { "type": "string", "enum": ["Credit Card", "Debit Card", "UPI", "Wallet"], "description": "The type of payment method." },
        "provider": { "type": "string", "description": "The provider (e.g., Visa, Mastercard, Google Pay)." },
        "lastFour": { "type": "string", "description": "Last four digits of the card or identifier." },
        "expiryDate": { "type": "string", "description": "Expiry date if applicable." },
        "isDefault": { "type": "boolean", "description": "Whether this is the default payment method." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the payment method was added." }
      },
      "required": ["userId", "type", "provider", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Trek booking documents."
    },
    "/users/{userId}/wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User's saved treks."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Public reviews shared by trekkers."
    },
    "/guides/{guideId}": {
      "schema": "Guide",
      "description": "Professional trek guides."
    },
    "/guideReviews/{reviewId}": {
      "schema": "GuideReview",
      "description": "Reviews for trek guides."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment transaction records."
    },
    "/authLogs/{logId}": {
      "schema": "AuthLog",
      "description": "User authentication logs."
    },
    "/users/{userId}/paymentMethods/{methodId}": {
      "schema": "PaymentMethod",
      "description": "User's saved payment methods."
    }
  }
}
